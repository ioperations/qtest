{
  "name": "qtest",
  "displayName": "Qtest",
  "description": "group of test code ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioperations/qtest.git"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myToolsSidebar",
          "title": "Tools",
          "icon": "img/p.svg"
        }
      ]
    },
    "views": {
      "myToolsSidebar": [
        {
          "icon": "./img/p.svg",
          "id": "myToolsView",
          "name": "My Tools",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "vite build --config vite.config.ts",
    "compile:webview": "vite build --config vite.webview.config.ts",
    "watch": "concurrently -n ext,web -c cyan,yellow \"npm run watch:extension\" \"npm run watch:webview\"",
    "watch:extension": "vite build --watch --config vite.config.ts",
    "watch:webview": "vite build --watch --config vite.webview.config.ts",
    "package": "npm run package:extension && npm run package:webview",
    "package:extension": "vite build --config vite.config.ts --mode production",
    "package:webview": "vite build --config vite.webview.config.ts --mode production",
    "vsce": "vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
