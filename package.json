{
  "name": "qtest",
  "displayName": "Qtest",
  "description": "group of test code ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioperations/qtest.git"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myToolsSidebar",
          "title": "Tools",
          "icon": "img/p.svg"
        }
      ]
    },
    "views": {
      "myToolsSidebar": [
        {
          "icon": "./img/p.svg",
          "id": "myToolsView",
          "name": "My Tools",
          "type": "webview"
        },
        {
          "id": "myToolsView2",
          "name": "My Tools2",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run compile:extension && yarn run compile:webview",
    "compile:extension": "webpack",
    "compile:webview": "webpack --config webpack.webview.config.js",
    "watch": "concurrently \"yarn run watch:extension\" \"yarn run watch:webview\"",
    "watch:extension": "webpack --watch",
    "watch:webview": "webpack --config webpack.webview.config.js --watch",
    "package": "yarn run package:extension && yarn run package:webview",
    "package:extension": "webpack --mode production --devtool hidden-source-map",
    "package:webview": "webpack --config webpack.webview.config.js --mode production --devtool hidden-source-map",
    "vsce": "vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.3",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
